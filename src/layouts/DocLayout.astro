---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import type { SidebarItem } from '../components/Sidebar.astro';
import type { TocItem } from '../components/TableOfContents.astro';

interface Props {
  title: string;
  description?: string;
  sidebarItems?: SidebarItem[];
  headings?: TocItem[];
}

const { title, description, sidebarItems = [], headings = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="flex gap-8 py-8">
    {
      sidebarItems.length > 0 && (
        <Sidebar items={sidebarItems} currentPath={Astro.url.pathname} />
      )
    }

    <article class="flex-1 min-w-0">
      <div
        class="prose prose-slate dark:prose-invert max-w-none"
        data-pagefind-body
      >
        <slot />
      </div>
    </article>

    {headings.length > 0 && <TableOfContents headings={headings} />}
  </div>
</BaseLayout>
