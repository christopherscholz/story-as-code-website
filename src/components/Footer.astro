---

---

<footer
  class="border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 mt-16"
>
  <div class="max-w-[90rem] mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <span
          class="font-display text-lg font-semibold text-slate-900 dark:text-white"
          >Story as Code</span
        >
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400 max-w-xs">
          Declarative YAML specification for defining worlds as temporal graphs.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3
          class="font-display text-sm font-semibold text-slate-900 dark:text-white mb-3"
        >
          Specification
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="/schemas/"
              class="text-slate-500 dark:text-slate-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors"
              >Schema Reference</a
            >
          </li>
          <li>
            <a
              href="/examples/"
              class="text-slate-500 dark:text-slate-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors"
              >Examples</a
            >
          </li>
          <li>
            <a
              href="/scope/"
              class="text-slate-500 dark:text-slate-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors"
              >Scope & Boundaries</a
            >
          </li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h3
          class="font-display text-sm font-semibold text-slate-900 dark:text-white mb-3"
        >
          Community
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="/contributing/"
              class="text-slate-500 dark:text-slate-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors"
              >Contributing</a
            >
          </li>
          <li>
            <a
              href="/code-of-conduct/"
              class="text-slate-500 dark:text-slate-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors"
              >Code of Conduct</a
            >
          </li>
          <li>
            <a
              href="https://github.com/christopherscholz/story-as-code-spec"
              class="text-slate-500 dark:text-slate-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-8 pt-6 border-t border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-3"
    >
      <p class="text-xs text-slate-400 dark:text-slate-500">
        Apache License 2.0
      </p>
      <p class="text-xs text-slate-400 dark:text-slate-500">
        Built with <a
          href="https://astro.build"
          class="hover:text-violet-500 transition-colors"
          target="_blank"
          rel="noopener noreferrer">Astro</a
        >
        &middot; Styled with <a
          href="https://tailwindcss.com"
          class="hover:text-violet-500 transition-colors"
          target="_blank"
          rel="noopener noreferrer">Tailwind CSS</a
        >
      </p>
    </div>
  </div>
</footer>
