---
import { getEntry } from 'astro:content';
import DocLayout from '../layouts/DocLayout.astro';

const page = await getEntry('pages', 'scope');
let Content: any, headings: any[] = [];
if (page) {
  const rendered = await page.render();
  Content = rendered.Content;
  headings = rendered.headings;
}
---

<DocLayout title="Scope & Boundaries" headings={headings}>
  <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-6">Scope & Boundaries</h1>
  {Content && <Content />}
</DocLayout>
