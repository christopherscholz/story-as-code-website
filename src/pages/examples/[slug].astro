---
import { getCollection } from 'astro:content';
import DocLayout from '../../layouts/DocLayout.astro';
import { exampleSidebar } from '../../data/navigation';

export async function getStaticPaths() {
  const examples = await getCollection('examples');
  return examples.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
---

<DocLayout
  title={entry.data.title}
  description={entry.data.description}
  sidebarItems={exampleSidebar}
  headings={headings}
>
  <div class="mb-6">
    <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white mb-3">{entry.data.title}</h1>
    {entry.data.hasGraph && (
      <a
        href={`/examples/${entry.slug}/graph/`}
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-violet-50 dark:bg-violet-900/20 text-violet-600 dark:text-violet-400 text-sm font-medium hover:bg-violet-100 dark:hover:bg-violet-900/30 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        Interactive Graph Visualization
      </a>
    )}
  </div>
  <Content />
</DocLayout>
