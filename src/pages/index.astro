---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '@/utils/url';

const concepts = [
  {
    name: 'Nodes',
    desc: 'Entities in the world — characters, locations, objects, events, concepts',
    icon: '&#9679;',
  },
  {
    name: 'Edges',
    desc: 'Relationships and connections between nodes',
    icon: '&#8596;',
  },
  {
    name: 'Frames',
    desc: 'Temporal contexts with different topologies',
    icon: '&#9633;',
  },
  {
    name: 'Lenses',
    desc: 'Narrative perspective configurations',
    icon: '&#9673;',
  },
  {
    name: 'Beats',
    desc: 'Hierarchical narrative building blocks',
    icon: '&#9835;',
  },
  {
    name: 'Formats',
    desc: 'Output format definitions with pacing rules',
    icon: '&#9638;',
  },
];

const principles = [
  {
    name: 'Declarative',
    desc: 'The graph declares what exists and when; outputs are derived, never primary',
  },
  {
    name: 'Temporally rich',
    desc: 'Time is graph topology, supporting branches, loops, and retrocausality',
  },
  {
    name: 'Schema-flexible',
    desc: 'The type system is extensible for custom world rules',
  },
  {
    name: 'Format-agnostic',
    desc: 'Same world can produce tweets, prose, screenplays, comics, audio, or interactive experiences',
  },
];
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-20 sm:pt-24 sm:pb-28"
    >
      <div class="max-w-3xl">
        <p
          class="font-mono text-sm text-violet-600 dark:text-violet-400 tracking-wider uppercase mb-4"
        >
          JSON-LD Specification
        </p>
        <h1
          class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold text-slate-900 dark:text-white leading-[1.1] tracking-tight"
        >
          Story<br />
          <span class="text-violet-600 dark:text-violet-400">as Code</span>
        </h1>
        <p
          class="mt-6 text-lg sm:text-xl text-slate-600 dark:text-slate-400 leading-relaxed max-w-2xl"
        >
          Declarative JSON-LD specification for defining worlds as temporal
          graphs and deriving outputs from them. Think of it like a compiler:
          the world graph is your source, the output is your compiled result.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={url('/schemas/')}
            class="inline-flex items-center px-5 py-2.5 rounded-lg bg-violet-600 text-white text-sm font-medium hover:bg-violet-700 transition-colors shadow-sm"
          >
            Schema Reference
            <svg
              class="ml-2 w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path></svg
            >
          </a>
          <a
            href={url('/examples/')}
            class="inline-flex items-center px-5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
          >
            View Examples
          </a>
          <a
            href="https://github.com/christopherscholz/story-as-code-spec"
            class="inline-flex items-center px-5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="mr-2 w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
              ></path></svg
            >
            GitHub
          </a>
        </div>
      </div>
    </div>

    <!-- Decorative element -->
    <div
      class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-96 h-96 bg-violet-200/30 dark:bg-violet-800/10 rounded-full blur-3xl pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-0 left-1/2 translate-y-1/2 w-64 h-64 bg-amber-200/20 dark:bg-amber-800/10 rounded-full blur-3xl pointer-events-none"
    >
    </div>
  </section>

  <!-- Principles -->
  <section
    class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 py-16 border-t border-slate-200 dark:border-slate-800"
  >
    <h2
      class="font-display text-3xl font-bold text-slate-900 dark:text-white mb-10"
    >
      Core Principles
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {
        principles.map((p) => (
          <div class="group p-6 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-violet-300 dark:hover:border-violet-700 transition-colors">
            <h3 class="font-display text-lg font-semibold text-slate-900 dark:text-white mb-2">
              {p.name}
            </h3>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
              {p.desc}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Key Concepts -->
  <section
    class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 py-16 border-t border-slate-200 dark:border-slate-800"
  >
    <h2
      class="font-display text-3xl font-bold text-slate-900 dark:text-white mb-10"
    >
      Key Concepts
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        concepts.map((c) => (
          <div class="flex items-start gap-4 p-5 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-violet-300 dark:hover:border-violet-700 transition-colors">
            <span
              class="text-2xl text-violet-500 dark:text-violet-400 mt-0.5"
              set:html={c.icon}
            />
            <div>
              <h3 class="font-display font-semibold text-slate-900 dark:text-white">
                {c.name}
              </h3>
              <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                {c.desc}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Quick Start -->
  <section
    class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 py-16 border-t border-slate-200 dark:border-slate-800"
  >
    <h2
      class="font-display text-3xl font-bold text-slate-900 dark:text-white mb-4"
    >
      Quick Start
    </h2>
    <p class="text-slate-600 dark:text-slate-400 mb-6 max-w-2xl">
      A minimal world is a single <code>story.jsonld</code> — everything in one file:
    </p>
    <div class="max-w-3xl">
      <pre
        class="bg-slate-900! dark:bg-slate-950! text-slate-100! p-6 rounded-xl text-sm leading-relaxed overflow-x-auto"><code class="language-json"><span class="text-slate-500">// story.jsonld</span>
<span class="text-slate-300">&#123;</span>
  <span class="text-violet-300">"@context"</span>: <span class="text-amber-300">"https://story-as-code.dev/latest/context/sac.context.jsonld"</span>,
  <span class="text-violet-300">"type"</span>: <span class="text-amber-300">"Story"</span>,
  <span class="text-violet-300">"id"</span>: <span class="text-amber-300">"a-simple-fairy-tale"</span>,
  <span class="text-violet-300">"specVersion"</span>: <span class="text-amber-300">"dev"</span>,
  <span class="text-violet-300">"name"</span>: <span class="text-amber-300">"A Simple Fairy Tale"</span>,
  <span class="text-violet-300">"world"</span>: <span class="text-slate-300">&#123;</span>
    <span class="text-violet-300">"type"</span>: <span class="text-amber-300">"World"</span>,
    <span class="text-violet-300">"id"</span>: <span class="text-amber-300">"world-layer"</span>,
    <span class="text-violet-300">"nodes"</span>: <span class="text-slate-300">[</span>
      <span class="text-slate-300">&#123;</span> <span class="text-violet-300">"type"</span>: <span class="text-amber-300">"Node"</span>, <span class="text-violet-300">"id"</span>: <span class="text-amber-300">"hero"</span>, <span class="text-violet-300">"nodeType"</span>: <span class="text-amber-300">"CHARACTER"</span>, <span class="text-violet-300">"name"</span>: <span class="text-amber-300">"Hero"</span> <span class="text-slate-300">&#125;</span>,
      <span class="text-slate-300">&#123;</span> <span class="text-violet-300">"type"</span>: <span class="text-amber-300">"Node"</span>, <span class="text-violet-300">"id"</span>: <span class="text-amber-300">"village"</span>, <span class="text-violet-300">"nodeType"</span>: <span class="text-amber-300">"LOCATION"</span>, <span class="text-violet-300">"name"</span>: <span class="text-amber-300">"Village"</span> <span class="text-slate-300">&#125;</span>
    <span class="text-slate-300">]</span>
  <span class="text-slate-300">&#125;</span>
<span class="text-slate-300">&#125;</span></code></pre>
    </div>
    <p class="mt-6 text-sm text-slate-500 dark:text-slate-400">
      As projects grow, split items into separate files linked with <code
        >&#123;"@id": "..."&#125;</code
      > references. See the <a
        href={url('/examples/')}
        class="text-violet-600 dark:text-violet-400 hover:underline"
        >full examples</a
      > for complete, working projects.
    </p>
  </section>

  <!-- Two-Layer Architecture -->
  <section
    class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 py-16 border-t border-slate-200 dark:border-slate-800"
  >
    <h2
      class="font-display text-3xl font-bold text-slate-900 dark:text-white mb-10"
    >
      Two-Layer Architecture
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div
        class="p-6 rounded-xl border-2 border-emerald-200 dark:border-emerald-800 bg-emerald-50/50 dark:bg-emerald-900/10"
      >
        <div class="flex items-center gap-2 mb-3">
          <span class="w-3 h-3 rounded-full bg-emerald-500"></span>
          <h3
            class="font-display text-lg font-semibold text-slate-900 dark:text-white"
          >
            World Layer
          </h3>
        </div>
        <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">
          The ground truth. Everything that exists — entities, relationships,
          timelines, rules.
        </p>
        <div class="flex flex-wrap gap-2">
          {
            ['World', 'Time System', 'Node', 'Edge', 'Frame', 'Constraint'].map(
              (s) => (
                <a
                  href={url(`/schemas/${s.toLowerCase().replace(' ', '-')}/`)}
                  class="text-xs font-mono px-2 py-1 rounded bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 hover:bg-emerald-200 dark:hover:bg-emerald-800/40 transition-colors"
                >
                  {s}
                </a>
              ),
            )
          }
        </div>
      </div>
      <div
        class="p-6 rounded-xl border-2 border-violet-200 dark:border-violet-800 bg-violet-50/50 dark:bg-violet-900/10"
      >
        <div class="flex items-center gap-2 mb-3">
          <span class="w-3 h-3 rounded-full bg-violet-500"></span>
          <h3
            class="font-display text-lg font-semibold text-slate-900 dark:text-white"
          >
            Narrative Layer
          </h3>
        </div>
        <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">
          The storytelling perspective. How the world is told: perspective,
          selection, format, structure.
        </p>
        <div class="flex flex-wrap gap-2">
          {
            ['Lens', 'Format', 'Beat', 'Device', 'Thread', 'Variant Meta'].map(
              (s) => (
                <a
                  href={url(`/schemas/${s.toLowerCase().replace(' ', '-')}/`)}
                  class="text-xs font-mono px-2 py-1 rounded bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300 hover:bg-violet-200 dark:hover:bg-violet-800/40 transition-colors"
                >
                  {s}
                </a>
              ),
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Status -->
  <section
    class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 py-16 border-t border-slate-200 dark:border-slate-800 mb-8"
  >
    <div
      class="p-6 rounded-xl bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-800"
    >
      <p class="text-sm text-amber-800 dark:text-amber-200">
        <strong class="font-display">Active Development</strong> — The core concepts
        are defined but subject to change. Feedback and contributions are <a
          href={url('/contributing/')}
          class="underline hover:text-amber-600 dark:hover:text-amber-300"
          >welcome</a
        >.
      </p>
    </div>
  </section>
</BaseLayout>
