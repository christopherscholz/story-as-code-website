{
  "name": "story-as-code-website",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "generate": "bash scripts/generate-schema-docs.sh && python3 scripts/generate-example-docs.py && python3 scripts/resolve-story.py",
    "prepare-content": "node scripts/prepare-content.mjs",
    "dev": "npm run prepare-content && astro dev",
    "build": "npm run prepare-content && astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "^5.7.10"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.4",
    "tailwindcss": "^4.1.4",
    "pagefind": "^1.3.0",
    "rehype-slug": "^6.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "sharp": "^0.33.5"
  }
}
