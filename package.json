{
  "name": "story-as-code-website",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "generate": "bash scripts/generate-schema-docs.sh && python3 scripts/generate-example-docs.py && python3 scripts/resolve-story.py",
    "prepare-content": "node scripts/prepare-content.mjs",
    "dev": "npm run prepare-content && astro dev",
    "build": "npm run prepare-content && astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,mjs,ts,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yaml,yml}": "prettier --write"
  },
  "dependencies": {
    "astro": "^5.7.10"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.4",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "lint-staged": "^16.4.0",
    "pagefind": "^1.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.33.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.4",
    "typescript-eslint": "^8.57.1"
  }
}
